# Kosongkan jika tidak pakai OpenAI
OPENAI_API_KEY=
TIMEZONE=Asia/Jakarta
DB_PATH=./data/tasks.db
RESEARCH_MODE=false
ADMIN_PHONE=6281234567890
DASHBOARD_PASSWORD=change-this-password
ADMIN_PORT=3000
ADMIN_HOST=127.0.0.1
# Wajib diganti dengan string acak minimal 32 karakter.
ADMIN_SESSION_SECRET=replace-with-random-secret-min-32-chars
AI_SUGGEST_RATE_LIMIT_MAX=20
AI_SUGGEST_RATE_LIMIT_WINDOW_MS=3600000
RESEARCH_RETENTION_DAYS=180
MAX_VOICE_NOTE_DURATION_MS=300000
MAX_VOICE_NOTE_BYTES=15728640
CHROME_EXECUTABLE_PATH=

# Provider transkripsi: auto | openai | whisper_cpp
TRANSCRIPTION_PROVIDER=auto

# Provider parsing tugas: auto | openai | rule_based
TASK_PARSER_PROVIDER=auto

# Model speech OpenAI (jika provider openai)
OPENAI_WHISPER_MODEL=whisper-1

# Konfigurasi whisper.cpp (jika provider whisper_cpp atau auto fallback)
WHISPER_CPP_PATH=whisper-cli
WHISPER_MODEL_PATH=
WHISPER_LANGUAGE=id
